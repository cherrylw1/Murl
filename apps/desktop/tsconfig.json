{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/renderer/**/*"
  ]
}
